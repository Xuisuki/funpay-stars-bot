# ============ Funpay-Telegram-Stars — конфигурация ============
# Скопируйте в .env и заполните. НЕ коммитьте .env (он в .gitignore).
# Проще всего: python first_start.py
#
# Проект: ProdX (https://prodx.pro) | dev @Xuisuki (https://github.com/Xuisuki)

# --- бренд ОПЕРАТОРА (в баннере терминала; пусто = имя FunPay-аккаунта) ---
BRAND_NAME=
BRAND_TAGLINE=

# --- FunPay ---
FUNPAY_AUTH_TOKEN=golden_key_из_cookie      # 32 символа
FUNPAY_USER_AGENT=                          # опционально
STARS_SUBCATEGORY_ID=2418                   # подкатегория FunPay с заказами Stars
DEACTIVATE_CATEGORY_ID=2418                 # категория лотов для авто-выключения

# --- Fragment (SELF-HOSTED: seed остаётся ЛОКАЛЬНО, наружу не уходит) ---
FRAGMENT_SEED=слова seed фразы через пробел # СЕКРЕТ TON-кошелька-расходника
TON_API_KEY=ключ_с_tonconsole.com
FRAGMENT_COOKIES=stel_ssid=...; stel_token=...; stel_ton_token=...   # куки сессии fragment.com
FRAGMENT_WALLET_VERSION=V5R1                # версия кошелька (V5R1 = W5, V4R2 ...)
FRAGMENT_PAYMENT_METHOD=ton                 # ton (дешевле газ) или usdt_ton
FRAGMENT_SHOW_SENDER=false
FRAGMENT_MIN_BALANCE=1.0                    # мин. баланс TON для выдачи

# --- поведение выдачи ---
DRY_RUN=true                                # true = БЕЗ реальной отправки (обкатка). Боевой режим: false
STARS_MULTIPLY_BY_AMOUNT=true               # умножать звёзды-за-лот на количество купленных
PREFLIGHT_BALANCE=true                      # проверять баланс перед отправкой
AUTO_REFUND_ON_FAIL=false                   # авто-возврат только при явном low_balance
AUTO_DEACTIVATE=true                        # гасить лоты при низком балансе
LEDGER_DB=orders.db

# --- пейсер человеческих задержек (по чату) ---
PACER_ENABLED=true
REPLY_DELAY_MIN=15
REPLY_DELAY_PER_ORDER=18
REPLY_DELAY_OFFSET=30
REPLY_DELAY_MAX=600
REPLY_JITTER=0.15

# --- Telegram-алерты оператору (отдельный бот от @BotFather) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_IDS=                         # ваши TG id через запятую

# --- бонус за отзыв ---
REVIEW_BONUS_STARS=1
REVIEW_SWEEP_INTERVAL=1200

# --- экономика/статистика ---
COST_USDT_PER_50=0.75
USDT_RUB=72.0
BALANCE_CHECK_INTERVAL=600
BALANCE_WARN_TON=0.5
BALANCE_CRIT_TON=0.1
